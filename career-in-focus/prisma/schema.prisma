// Career In Focus — Prisma Schema
// Hebrew RTL membership community for job seekers in Israel

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum AccessStatus {
  PENDING     // Registered but not paid
  ACTIVE      // Paid and approved
  SUSPENDED   // Suspended by admin
  EXPIRED     // Membership expired
}

enum MembershipType {
  NONE
  MEMBER
  VIP
  PREMIUM  // "קורל מפעילה קשרים" tier
}

enum NetworkRequestStatus {
  PENDING
  IN_PROGRESS
  DONE
  DECLINED
}

enum PaymentProvider {
  NONE
  CARDCOM
  MANUAL
}

enum ApplicationStatus {
  SAVED
  FIT_CHECKED
  APPLIED
  PROACTIVE_OUTREACH
  FOLLOWUP_SENT
  INTERVIEW_SCHEDULED
  FIRST_INTERVIEW
  ADVANCED_INTERVIEW
  TASK_HOME
  OFFER
  REJECTED
  FROZEN
  ACCEPTED
}

enum EventType {
  WEBINAR
  WORKSHOP
  LIVE
  GUEST_RECRUITER
  JOB_DROP
  LAUNCH
  NETWORKING
}

enum PostCategory {
  QUESTION
  JOB
  WIN
  TIP
}

enum ToolType {
  AI_TOOL
  TEMPLATE
  LINK
  FILE
  COURSE_RESOURCE
  QUESTIONNAIRE
  JOB_SOURCE
  WHATSAPP_GROUP
  FACEBOOK_GROUP
  CV_TEMPLATE
  OTHER
}

enum CourseFormat {
  TEXT
  PDF
  VIDEO
  EXTERNAL_LINK
  EMBEDDED
  EXTERNAL_PLATFORM
  DOWNLOAD_BUNDLE
}

enum AccessType {
  FREE
  INCLUDED
  DISCOUNTED
  PAID
}

enum PhotoUpgradeStatus {
  NONE
  REQUESTED
  IN_PROGRESS
  DELIVERED
}

// ─── Auth Models ──────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  passwordHash  String?
  // Gender is captured at signup so we can address the member correctly
  // in welcome emails, the dashboard, and any future copy. "f" = female,
  // "m" = male; null = unknown (older users from before this field
  // existed, or admin-created users where gender wasn't supplied).
  gender        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Role & Access
  role          Role         @default(MEMBER)
  accessStatus  AccessStatus @default(PENDING)
  membershipType MembershipType @default(NONE)

  // Payment
  paymentProvider  PaymentProvider @default(NONE)
  paymentReference String?
  paidAt           DateTime?
  cardToken        String?   // CardCom recurring token
  cardLast4        String?   // last 4 digits for display

  // Subscription / recurring billing
  subscriptionStatus  String?   // "ACTIVE" | "CANCELLED" | "PAUSED" | null (legacy)
  nextChargeAt        DateTime? // when the cron should next charge this user
  lastChargedAt       DateTime? // last successful recurring charge
  chargeCount         Int       @default(0) // how many monthly cycles billed
  cancelledAt         DateTime? // when the user clicked cancel (or null)
  cancellationReason  String?   // FOUND_JOB | NO_VALUE | STOPPED_SEARCH | OTHER
  cancellationNote    String?   // free-text follow-up

  // Active devices — anti-account-sharing. We allow MAX_DEVICES_PER_USER
  // (3) concurrent logins per user, identified by hashed user-agent. On
  // a 4th device the oldest one (by lastSeenAt) is auto-deactivated.
  devices             UserDevice[]

  // Profile
  profile       Profile?
  careerPassport CareerPassport?

  // Relations
  accounts      Account[]
  sessions      Session[]
  jobApplications JobApplication[]
  jobApplicationJournalEntries JobApplicationJournalEntry[]
  jobApplicationReminders JobApplicationReminder[]
  courseCompletions UserCourseCompletion[]
  skillCompletions  UserSkillCompletion[]
  posts         Post[]
  comments      Comment[]
  likes         Like[]
  notifications Notification[]
  coachingSession CoachingSession?
  networkRequests NetworkRequest[]
  premiumLeads    PremiumLead[]
  broadcastsSent  BroadcastLog[]
  photoUpgradeStatus PhotoUpgradeStatus @default(NONE)
  photoUpgradeRequestedAt DateTime?

  // Whether to email this user when a new job matches their profile (≥60%).
  // Default true for active members; can be flipped from settings if we add
  // an unsubscribe page later.
  emailJobAlerts Boolean @default(true)
}

// One row per (user, device fingerprint). The fingerprint is the SHA-256
// of the User-Agent header — stable across IP changes (so a legitimate
// VPN user isn't penalised) but distinct per device/browser. We allow
// at most 3 active devices per user; on a 4th login the oldest one
// flips isActive=false.

model UserDevice {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fingerprint  String   // SHA-256 of normalized User-Agent
  userAgent    String?  // human-readable for the device list UI
  lastIp       String?  // last seen IP (for admin sanity; not used to gate access)
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  isActive     Boolean  @default(true)

  @@unique([userId, fingerprint])
  @@index([userId, lastSeenAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

// ─── Profile & Career Passport ────────────────────────────────────────────────

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt       DateTime @updatedAt

  // Basic
  fullName        String?
  phone           String?
  currentRole     String?
  targetRole      String?
  yearsExperience Int?
  desiredField    String?

  // Career Goals
  careerTransitionGoal String?
  mainChallenge        String?
  strengths            String?  // JSON array
  missingSkills        String?  // JSON array

  // Preferences
  preferredSalaryMin Int?
  preferredSalaryMax Int?
  preferredCompanyType String?

  // Links & Files
  linkedinUrl     String?
  resumeUrl       String?
  imageUrl        String?

  // Questionnaire completion
  questionnaireCompleted Boolean @default(false)

  // Career Passport Questionnaire fields
  q_workStyle          String?
  q_teamOrSolo         String?
  q_motivators         String?
  q_biggestFear        String?
  q_idealDay           String?
  q_pastAchievement    String?
  q_learningStyle      String?
  q_shortTermGoal      String?
  q_longTermGoal       String?
  q_networkingLevel    String?
  q_salaryPriority     String?
  q_locationFlexible   Boolean?
  q_remotePreference   String?
  q_industryInterests  String?  // JSON array
  q_roleModels         String?
  q_valuesAtWork       String?  // JSON array

  // ── Job-search status fields ─────────────────────────────────────
  // Captured in the new "הגדרת חיפוש העבודה שלך" wizard (step 3).
  // Drives the AI coach + dashboard "next action" suggestions.
  // js_actively  : null | "yes" | "no" | "passive"
  // js_searchWeeks  : how many weeks the user has been searching
  // js_recentInterviews  : count in the last month (rough self-report)
  // js_isApplying  : has the user started sending applications
  js_actively         String?
  js_searchWeeks      Int?
  js_recentInterviews Int?
  js_isApplying       Boolean?

  // ── Professional assets (step 4) ─────────────────────────────────
  portfolioUrl     String?
  additionalLinks  String?  // JSON array of { label, url }
}

model CareerPassport {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  generatedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  jobMatchScore   Int      @default(0)
  strengths       String?  // JSON array
  skillGaps       String?  // JSON array
  recommendations String?  // JSON array
  likelyFitRoles  String?  // JSON array
  recommendedIndustries String?  // JSON array
  nextBestActions String?  // JSON array
  summary         String?
}

// ─── Job Applications Tracker ────────────────────────────────────────────────

model JobApplication {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       String
  role          String
  dateApplied   DateTime?
  source        String?
  status        ApplicationStatus @default(APPLIED)
  notes         String?
  nextFollowUp  DateTime?

  // Extra tracking
  contactName   String?
  contactLinkedin String?
  jobLink       String?
  responseReceived Boolean @default(false)
  interviewStage  String?

  // Job-search-as-an-OS additions:
  interviewDate DateTime?      // Scheduled interview (used for countdown + prep)
  nextStep      String?        // Free text — "what's the next thing to do"
  priority      Int?           // 1=low 2=medium 3=high
  archived      Boolean @default(false)

  journal       JobApplicationJournalEntry[]
  reminders     JobApplicationReminder[]
}

// ─── Journal entries per application ─────────────────────────────────────────

enum JournalEntryTag {
  INTERVIEW
  FOLLOWUP
  NOTE
  FEELING
  LEARNING
  OUTREACH
}

model JobApplicationJournalEntry {
  id            String   @id @default(cuid())
  applicationId String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  occurredAt    DateTime @default(now())

  text          String
  tag           JournalEntryTag?

  @@index([applicationId, occurredAt])
  @@index([userId, occurredAt])
}

// ─── User completions (auto-update Career Passport on each completion) ──────

model UserCourseCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completedAt DateTime @default(now())

  @@unique([userId, courseId])
  @@index([userId])
}

model UserSkillCompletion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillName   String
  completedAt DateTime @default(now())

  @@unique([userId, skillName])
  @@index([userId])
}

// ─── Reminders per application ───────────────────────────────────────────────

enum ReminderType {
  FOLLOWUP
  INTERVIEW_PREP
  THANK_YOU
  RESEARCH
  OTHER
}

model JobApplicationReminder {
  id            String   @id @default(cuid())
  applicationId String
  application   JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  dueAt         DateTime
  type          ReminderType @default(OTHER)
  title         String
  notes         String?
  completed     Boolean @default(false)
  completedAt   DateTime?

  @@index([applicationId, dueAt])
  @@index([userId, dueAt, completed])
}

// ─── Courses ─────────────────────────────────────────────────────────────────

model Course {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  title       String
  description String?
  category    String?
  formatType  String?  // flexible free text
  accessType  AccessType @default(INCLUDED)
  isPublished Boolean @default(true)
  imageUrl    String?
  ctaText     String?
  ctaUrl      String?
  sortOrder   Int @default(0)

  contents    CourseContent[]
  completions UserCourseCompletion[]
}

model CourseContent {
  id        String      @id @default(cuid())
  courseId  String
  course    Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)

  format    CourseFormat
  title     String?
  body      String?     // text content or embed code
  url       String?
  fileUrl   String?
  sortOrder Int @default(0)
}

// ─── Tools & Resources ───────────────────────────────────────────────────────

model Tool {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  title       String
  description String?
  category    String?
  type        ToolType @default(LINK)
  externalUrl String?
  fileUrl     String?
  imageUrl    String?
  adminTip    String?
  notes       String?
  targetRole  String?
  isPublished Boolean @default(true)
  sortOrder   Int @default(0)
}

// ─── Jobs ─────────────────────────────────────────────────────────────────────

// ─── Market Intelligence Feed ────────────────────────────────────────────────
//
// Replaces the old "עדכונים והודעות" page. Articles are auto-collected
// from configured sources, processed by Gemini (translate → summarize →
// generate insight + recommended action), filtered for relevance to job
// seekers, and published automatically. Admin can hide / edit / pin
// individual rows after the fact via /admin/market-intel.

model MarketIntelArticle {
  id                String   @id @default(cuid())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // ─── Source ─────
  originalTitle     String
  originalUrl       String   @unique
  sourceName        String
  language          String   // "he" or "en"
  publishedAt       DateTime
  detectedAt        DateTime @default(now())

  // ─── Hebrew-first processed content ─────
  hebrewTitle       String
  summaryHebrew     String                          // 3-5 lines
  whyItMatters      String                          // why this matters to job seekers
  jobSearchInsight  String                          // practical takeaway
  recommendedAction String                          // single concrete action

  // ─── Classification ─────
  category          String                          // שוק העבודה / AI ותעסוקה / וכו׳
  importanceLabel   String?                         // חשוב למחפשי עבודה / וכו׳
  relevanceScore    Int      @default(50)           // 0-100; below threshold not published

  // ─── Visibility / curation ─────
  status            String   @default("PUBLISHED")  // PUBLISHED / HIDDEN / DRAFT
  isPinned          Boolean  @default(false)
  isFeatured        Boolean  @default(false)

  @@index([status, publishedAt])
  @@index([category])
}

model Job {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  title       String
  company     String
  companyLogo String?
  summary     String?
  description String?
  location    String?
  /// One of the seven Hebrew regions in lib/regions.ts
  /// (צפון / חיפה / מרכז / שפלה / ירושלים / דרום / אילת),
  /// or null when the city couldn't be classified.
  region      String?
  field       String?
  experienceLevel String?
  source      String?
  externalUrl String?
  isHot       Boolean @default(false)
  isPublished Boolean @default(true)
  expiresAt   DateTime?

  alerts      JobAlert[]
}

// One row per (job, user) every time we email a member about a new
// matching job. Daily cron uses the unique constraint to avoid emailing
// the same person twice for the same job, even if the matching score
// recomputes higher next day.
model JobAlert {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  userId    String
  score     Int      // match score at time of send, 0-100
  sentAt    DateTime @default(now())

  @@unique([jobId, userId])
  @@index([userId, sentAt])
}

// Cached CV-feedback analyses keyed by (userId, content-hash). Re-uploads
// of the exact same file resolve from cache instead of re-billing
// Gemini. The latest row per user (by createdAt desc) drives the
// /progress/cv-feedback "your last analysis" view.
model CvFeedback {
  id          String   @id @default(cuid())
  userId      String
  contentHash String   // SHA-256 hex of file bytes
  fileName    String
  result      String   // JSON-serialized CvFeedbackResult — see /api/cv-feedback/analyze
  createdAt   DateTime @default(now())

  @@unique([userId, contentHash])
  @@index([userId, createdAt])
}

// ─── Events ──────────────────────────────────────────────────────────────────

model Event {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdById String?

  title       String
  description String?
  type        EventType @default(WEBINAR)
  startAt     DateTime
  endAt       DateTime?
  location    String?
  isOnline    Boolean   @default(true)
  meetingUrl  String?
  registerUrl String?
  isPublished Boolean   @default(true)
  maxCapacity Int?
  imageUrl    String?

  // ─── Workshop card structured fields (used by /events) ─────
  audience     String?  // קהל יעד — "מחפשי עבודה בכל התחומים"
  valueBullets String?  // JSON array of 3-5 short bullets
  host         String?  // שם המנחה
  hostRole     String?  // תפקיד המנחה — "מגייסת טכנולוגית בכירה"
}

// ─── Community ────────────────────────────────────────────────────────────────

model Post {
  id        String      @id @default(cuid())
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  authorId  String
  author    User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  category  PostCategory
  content   String
  imageUrl  String?
  isPinned  Boolean     @default(false)
  isHidden  Boolean     @default(false)

  comments  Comment[]
  likes     Like[]
}

model Comment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  content   String
  isHidden  Boolean @default(false)
}

model Like {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

// ─── Updates / Announcements ─────────────────────────────────────────────────

model Update {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  title       String
  content     String
  category    String?  // e.g., "market", "launch", "event", "recruiter", "general"
  isPinned    Boolean  @default(false)
  isPublished Boolean  @default(true)
  imageUrl    String?
  ctaText     String?
  ctaUrl      String?
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // "event", "update", "job_match", "community_reply", "photo_upgrade", "general"
  title     String
  message   String
  link      String?
  isRead    Boolean  @default(false)
  refId     String?  // Reference to the related entity
}

// ─── Featured Candidate ───────────────────────────────────────────────────────

model FeaturedCandidate {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  userId      String?  // optional link to a real user
  name        String
  targetRole  String
  summary     String?
  strengths   String?  // JSON array
  lookingFor  String?
  imageUrl    String?
  linkedinUrl String?
  isActive    Boolean  @default(true)
  weekOf      DateTime @default(now())
}

// ─── AI Coaching ─────────────────────────────────────────────────────────────

model CoachingSession {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // messages stored as JSON array [{role, content}]
  messages    String   @default("[]")
  // latest AI analysis snapshot
  lastAnalysis String?
  analyzedAt   DateTime?
}

// ─── Premium Network Requests ─────────────────────────────────────────────────

model NetworkRequest {
  id          String              @id @default(cuid())
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetRole     String
  targetCompanies String?   // comma-separated
  notes          String?
  status         NetworkRequestStatus @default(PENDING)
  adminNote      String?
}

// ─── Premium Lead ("קורל תפעילי קשרים") ──────────────────────────────────────

enum PremiumLeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  IN_PROGRESS
  CLOSED
  DECLINED
}

model PremiumLead {
  id          String            @id @default(cuid())
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Contact info (may or may not be a registered user)
  userId      String?
  user        User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  fullName    String
  phone       String
  email       String
  targetRole  String
  description String?           // "ספר בקצרה מה אתה מחפש"
  whyNow      String?           // "למה דווקא עכשיו"

  status      PremiumLeadStatus @default(NEW)
  adminNote   String?
}

// ─── Progress Tracking ────────────────────────────────────────────────────────

model ProgressSnapshot {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  userId      String

  // Weekly snapshot of metrics
  weekStart   DateTime
  applied     Int @default(0)
  responses   Int @default(0)
  interviews  Int @default(0)
  offers      Int @default(0)
  rejections  Int @default(0)
  outreach    Int @default(0)
  networking  Int @default(0)
  skills      Int @default(0)
}

// ─── Broadcast Log ────────────────────────────────────────────────────────────

model BroadcastLog {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())
  subject      String
  body         String
  audience     String   @default("ALL")
  sentCount    Int      @default(0)
  skippedCount Int      @default(0)
  sentById     String
  sentBy       User     @relation(fields: [sentById], references: [id])
}

// ─── Recruiter Directory ──────────────────────────────────────────────────────

enum RecruiterType {
  RECRUITER       // מגייס בחברה
  STAFFING        // חברת השמה
  HEADHUNTER      // הד האנטר
}

model Recruiter {
  id          String        @id @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  name        String
  company     String
  email       String?
  phone       String?
  linkedinUrl String?
  type        RecruiterType @default(RECRUITER)
  field       String?       // תחום התמחות (hi-tech, finance, etc.)
  notes       String?       // הערות פנימיות
  isActive    Boolean       @default(true)
}
